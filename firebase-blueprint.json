{
  "entities": {
    "loan": {
      "title": "Loan",
      "description": "Represents a loan given to a client.",
      "type": "object",
      "properties": {
        "clientName": {
          "type": "string",
          "description": "The name of the client."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date the loan was issued."
        },
        "capital": {
          "type": "number",
          "description": "The principal amount borrowed."
        },
        "interestRate": {
          "type": "number",
          "description": "The monthly interest rate (fixed at 0.10)."
        },
        "totalBruto": {
          "type": "number",
          "description": "The total amount to be received (Capital + Interest)."
        },
        "status": {
          "type": "string",
          "enum": ["Pendente", "Pago", "Atrasado"],
          "description": "The current status of the loan."
        },
        "uid": {
          "type": "string",
          "description": "The UID of the user who created the loan."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the record was created."
        }
      },
      "required": ["clientName", "date", "capital", "interestRate", "totalBruto", "status", "uid", "createdAt"]
    },
    "user": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string", "description": "The custom name of the user for receipts." },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "uid": { "type": "string" }
      },
      "required": ["email", "role", "uid"]
    },
    "system_action": {
      "title": "System Action",
      "description": "Represents an action performed in the system.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "clientName": { "type": "string" },
        "loanId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["type", "description", "clientName", "loanId", "date", "uid"]
    }
  },
  "firestore": {
    "/loans/{loanId}": {
      "schema": "loan",
      "description": "Collection of all loans."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "User profile data."
    },
    "/actions/{actionId}": {
      "schema": "system_action",
      "description": "Log of all system actions."
    }
  }
}

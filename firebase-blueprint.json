{
  "entities": {
    "loan": {
      "title": "Loan",
      "description": "Represents a loan given to a client.",
      "type": "object",
      "properties": {
        "clientName": {
          "type": "string",
          "description": "The name of the client."
        },
        "clientPhone": {
          "type": "string",
          "description": "The phone number of the client."
        },
        "clientAddress": {
          "type": "string",
          "description": "The address of the client."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date the loan was issued."
        },
        "dueDate": {
          "type": "string",
          "format": "date",
          "description": "The date the loan is due."
        },
        "capital": {
          "type": "number",
          "description": "The principal amount borrowed."
        },
        "interestRate": {
          "type": "number",
          "description": "The monthly interest rate."
        },
        "totalBruto": {
          "type": "number",
          "description": "The total amount to be received (Capital + Interest)."
        },
        "capitalPago": {
          "type": "number",
          "description": "Total principal paid back."
        },
        "jurosPagos": {
          "type": "number",
          "description": "Total interest paid."
        },
        "status": {
          "type": "string",
          "enum": ["Pendente", "Pago", "Atrasado", "Agendado"],
          "description": "The current status of the loan."
        },
        "uid": {
          "type": "string",
          "description": "The UID of the user who created the loan."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the record was created."
        }
      },
      "required": ["clientName", "date", "dueDate", "capital", "interestRate", "totalBruto", "status", "uid", "createdAt", "capitalPago", "jurosPagos"]
    },
    "user": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string", "description": "The custom name of the user for receipts." },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "uid": { "type": "string" }
      },
      "required": ["email", "role", "uid"]
    },
    "system_action": {
      "title": "System Action",
      "description": "Represents an action performed in the system.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "clientName": { "type": "string" },
        "loanId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" },
        "confirmed": { "type": "boolean", "description": "Whether the transaction has been verified." }
      },
      "required": ["type", "description", "clientName", "loanId", "date", "uid"]
    },
    "monthly_closure": {
      "title": "Monthly Closure",
      "description": "Represents a monthly financial closure.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "closedAt": { "type": "string", "format": "date-time" },
        "closurePeriodEnd": { "type": "string", "format": "date-time" },
        "stats": {
          "type": "object",
          "properties": {
            "totalLent": { "type": "number" },
            "totalPayments": { "type": "number" },
            "capitalPayments": { "type": "number" },
            "interestPayments": { "type": "number" },
            "paymentCount": { "type": "number" },
            "loanCount": { "type": "number" },
            "currentOutstanding": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "month", "year", "closedAt", "closurePeriodEnd", "stats"]
    },
    "system_settings": {
      "title": "System Settings",
      "description": "User-specific system configuration.",
      "type": "object",
      "properties": {
        "whatsappTemplate": { "type": "string" },
        "defaultInterestRate": { "type": "number" },
        "accentColor": { "type": "string", "enum": ["yellow", "green", "blue"] }
      },
      "required": ["whatsappTemplate", "defaultInterestRate", "accentColor"]
    }
  },
  "firestore": {
    "/loans/{loanId}": {
      "schema": "loan",
      "description": "Collection of all loans."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "User profile data."
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": "system_settings",
      "description": "User-specific settings (e.g. system)."
    },
    "/actions/{actionId}": {
      "schema": "system_action",
      "description": "Log of all system actions."
    },
    "/monthly_closures/{closureId}": {
      "schema": "monthly_closure",
      "description": "History of monthly closures."
    }
  }
}

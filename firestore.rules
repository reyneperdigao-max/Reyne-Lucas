rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==========================================
    // 0. Global Safety Net
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // Phase 3: Primitive Definition
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && request.auth.uid == resource.data.uid;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerifiedUser() {
      // Relaxing email verification for development/preview to avoid blocking users
      return isSignedIn();
    }

    function isAdmin() {
      // Explicitly checking for the bootstrap admin email
      return isSignedIn() && request.auth.token.email == 'reyneperdigao@gmail.com';
    }

    // ==========================================
    // Phase 4: Validation Blueprints
    // ==========================================

    function isValidUser(data) {
      let requiredFields = ['role', 'uid'];
      return data.keys().hasAll(requiredFields) &&
             (data.email == null || (data.email is string && data.email.size() < 256)) &&
             data.role in ['admin', 'user'] &&
             data.uid == request.auth.uid &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('pixKey' in data) || (data.pixKey is string && data.pixKey.size() <= 200)) &&
             (!('pixName' in data) || (data.pixName is string && data.pixName.size() <= 100)) &&
             (!('pixBank' in data) || (data.pixBank is string && data.pixBank.size() <= 100)) &&
             (!('profilePicture' in data) || (data.profilePicture == null || (data.profilePicture is string && data.profilePicture.size() <= 2000000)));
    }

    function isValidLoan(data) {
      let requiredFields = ['clientName', 'date', 'dueDate', 'capital', 'interestRate', 'totalBruto', 'status', 'uid', 'createdAt', 'capitalPago', 'jurosPagos'];
      return data.keys().hasAll(requiredFields) &&
             data.clientName is string && data.clientName.size() > 0 && data.clientName.size() <= 100 &&
             data.date is string && data.date.size() <= 20 &&
             data.dueDate is string && data.dueDate.size() <= 20 &&
             data.capital is number && (data.status == 'Pago' ? data.capital >= 0 : data.capital >= 0) &&
             data.interestRate is number && data.interestRate >= 0 &&
             data.totalBruto is number &&
             data.status in ['Pendente', 'Pago', 'Atrasado', 'Agendado'] &&
             data.uid == request.auth.uid &&
             data.capitalPago is number &&
             data.jurosPagos is number &&
             (!('clientPhone' in data) || (data.clientPhone is string && data.clientPhone.size() <= 50)) &&
             (!('clientAddress' in data) || (data.clientAddress is string && data.clientAddress.size() <= 255));
    }

    function isCreatedAtImmutable() {
      return incoming().createdAt == existing().createdAt;
    }

    function isActiveTimestamp() {
      return incoming().createdAt == request.time;
    }

    function isValidAction(data) {
      let requiredFields = ['type', 'description', 'clientName', 'loanId', 'date', 'uid'];
      return data.keys().hasAll(requiredFields) &&
             data.type in ['loan_created', 'payment_received', 'loan_deleted', 'loan_updated', 'loan_scheduled', 'loan_activated', 'loan_renewed'] &&
             data.description is string && data.description.size() <= 500 &&
             data.clientName is string && data.clientName.size() <= 100 &&
             data.loanId is string && data.loanId.size() <= 128 &&
             data.date is string && data.date.size() <= 50 &&
             data.uid == request.auth.uid &&
             (!('amount' in data) || (data.amount == null || data.amount is number)) &&
             (!('capitalAmount' in data) || (data.capitalAmount == null || data.capitalAmount is number)) &&
             (!('interestAmount' in data) || (data.interestAmount == null || data.interestAmount is number)) &&
             (!('paymentMethod' in data) || (data.paymentMethod == null || data.paymentMethod in ['DINHEIRO', 'PIX'])) &&
             (!('confirmed' in data) || (data.confirmed == null || data.confirmed is bool));
    }

    function isValidClosure(data) {
      let requiredFields = ['userId', 'month', 'year', 'closedAt', 'closurePeriodEnd', 'stats'];
      return data.keys().hasAll(requiredFields) &&
             data.userId == request.auth.uid &&
             data.month is number && data.month >= 0 && data.month <= 11 &&
             data.year is number &&
             data.closedAt is string &&
             data.closurePeriodEnd is string &&
             data.stats is map;
    }

    function isValidSystemSettings(data) {
      let requiredFields = ['whatsappTemplate', 'defaultInterestRate', 'accentColor'];
      return data.keys().hasAll(requiredFields) &&
             data.whatsappTemplate is string && data.whatsappTemplate.size() <= 2000 &&
             data.defaultInterestRate is number &&
             data.accentColor in ['yellow', 'green', 'blue', 'violet', 'red'];
    }

    // ==========================================
    // Collections
    // ==========================================

    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow list: if (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if (isOwner(userId) || isAdmin()) && (isValidUser(incoming()) || isAdmin()) && isValidId(userId) &&
                    incoming().uid == existing().uid &&
                    (incoming().role == existing().role || isAdmin());

      match /settings/{settingId} {
        allow get, list: if isOwner(userId) && isValidId(settingId);
        allow create, update: if isOwner(userId) && isValidSystemSettings(incoming()) && isValidId(settingId);
        allow delete: if isOwner(userId) && isValidId(settingId);
      }
    }

    match /loans/{loanId} {
      allow get: if isVerifiedUser() && isDocOwner() && isValidId(loanId);
      allow list: if isVerifiedUser() && resource.data.uid == request.auth.uid;
      allow create: if isVerifiedUser() && isValidLoan(incoming()) && isActiveTimestamp() && isValidId(loanId);
      allow update: if isVerifiedUser() && isValidId(loanId) && (isAdmin() || (isDocOwner() && isValidLoan(incoming()) &&
                    incoming().uid == existing().uid &&
                    isCreatedAtImmutable() && (
                      // Action: Financial/Status (Amortization, Payment, Renewal, Payoff)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'capital', 'totalBruto', 'capitalPago', 'jurosPagos', 'date', 'dueDate'])) ||
                      // Action: General Info Edit
                      (incoming().diff(existing()).affectedKeys().hasOnly(['clientName', 'clientPhone', 'clientAddress', 'date', 'dueDate', 'capital', 'interestRate', 'totalBruto']))
                    )));
      allow delete: if isVerifiedUser() && isDocOwner() && isValidId(loanId);
    }

    match /actions/{actionId} {
      allow get: if isVerifiedUser() && isDocOwner() && isValidId(actionId);
      allow list: if isVerifiedUser() && resource.data.uid == request.auth.uid;
      allow create: if isVerifiedUser() && isValidAction(incoming()) && isValidId(actionId);
      allow update: if isVerifiedUser() && (isAdmin() || (isDocOwner() && isValidAction(incoming()) &&
                    incoming().uid == existing().uid &&
                    incoming().loanId == existing().loanId));
      allow delete: if isVerifiedUser() && isDocOwner() && isValidId(actionId);
    }

    match /monthly_closures/{closureId} {
      allow get: if isVerifiedUser() && resource.data.userId == request.auth.uid && isValidId(closureId);
      allow list: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow create: if isVerifiedUser() && isValidClosure(incoming()) && isValidId(closureId);
      allow update: if isVerifiedUser() && (isAdmin() || (resource.data.userId == request.auth.uid && isValidClosure(incoming())));
      allow delete: if isVerifiedUser() && resource.data.userId == request.auth.uid && isValidId(closureId);
    }
  }
}
